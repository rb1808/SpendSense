rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SpendSense Security Rules
     *
     * Core Philosophy: This ruleset enforces a strict user-ownership model where all sensitive 
     * financial data is private by default. Access is strictly tied to the Firebase Authentication UID.
     *
     * Data Structure: All data is hierarchically organized under the /users/{userId} path. 
     * This includes the user's profile, custom categories, expenses, and budget goals.
     *
     * Key Security Decisions:
     * 1. Path-Based Authorization: The UID in the document path (/users/{userId}/...) must match 
     *    the authenticated user's UID (request.auth.uid). This provides a fast, zero-extra-read 
     *    security check for all operations.
     * 2. Denormalized Ownership: For redundant security and relational integrity, ownership fields 
     *    (like userId or id) are required within the document data and must match the path.
     * 3. No Public Access: There are no public collections. All data requires authentication.
     * 4. Prototyping Flexibility: While ownership is strictly enforced, data types and schema 
     *    shapes are not validated to allow for rapid UI/UX iteration.
     * 5. Immutability: Ownership links (userId fields) are immutable once a document is created.
     */

    // --- Global Helper Functions ---

    /** 
     * Checks if the request is made by an authenticated user. 
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Checks if the authenticated user's UID matches the provided userId from the path. 
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * Combines ownership check with a check that the document exists. 
     * Used for update and delete operations to ensure state-change robustness.
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile collection, storing settings and contact info.
     * @path /users/{userId}
     * @allow (get, create) Authenticated user with UID '123' accessing /users/123.
     * @deny (list) Any request attempting to list all users.
     * @principle Enforces path-based ownership and validates relational integrity of the ID field.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for user-specific categories (custom or personal copies of defaults).
       * @path /users/{userId}/categories/{categoryId}
       * @allow (create) User '123' creating a category with userId field set to '123'.
       * @deny (update) User '123' attempting to change the userId field of an existing category.
       * @principle Restricts access to a user's private data tree and ensures field immutability.
       */
      match /categories/{categoryId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for financial expense records.
       * @path /users/{userId}/expenses/{expenseId}
       * @allow (list) User 'abc' listing expenses under /users/abc/expenses.
       * @deny (get) User 'xyz' attempting to get a document at /users/abc/expenses/exp1.
       * @principle Prevents cross-user data leakage by isolating data under the UID path.
       */
      match /expenses/{expenseId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for monthly budget targets.
       * @path /users/{userId}/budgets/{budgetId}
       * @allow (delete) User '789' deleting their own budget record.
       * @deny (create) User '789' creating a budget with a userId field of 'admin'.
       * @principle Enforces strict ownership for writes and ensures state-changing operations target existing data.
       */
      match /budgets/{budgetId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}